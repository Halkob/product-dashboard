# Server Configuration
NODE_ENV=development
PORT=3001

# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/dashboard_dev"
DATABASE_URL_TEST="postgresql://user:password@localhost:5432/dashboard_test"

# Redis Configuration (Optional - used for REQ-005)
REDIS_URL="redis://localhost:6379"

# Frontend Configuration
REACT_APP_API_URL="http://localhost:3001/api"
REACT_APP_ENV="development"

# CORS Configuration (Development)
CORS_ORIGIN="http://localhost:3000"

# Logging Configuration
LOG_LEVEL="debug"

# JWT Configuration (REQ-002)
JWT_SECRET=change-me-use-a-long-random-secret
JWT_REFRESH_SECRET=change-me-use-a-different-long-random-secret
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
BCRYPT_ROUNDS=10
