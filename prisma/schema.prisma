// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// CORE DOMAIN MODELS - REQ-001 Foundation
// ============================================================================

// ============================================================================
// AUTH MODELS - REQ-002 User Authentication & Authorization
// ============================================================================

// User model - Authenticated application users
// Each user is assigned exactly one organisational role.
// Passwords are never stored in plaintext — only bcrypt hashes.
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  roleId       Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  role              Role           @relation(fields: [roleId], references: [id])
  refreshTokens     RefreshToken[]
  createdProjects   Project[]      @relation("ProjectCreatedBy")
  assignedIssues    Issue[]        @relation("IssueAssignee")
  reportedIssues    Issue[]        @relation("IssueReporter")
  comments          Comment[]
  activityLogs      ActivityLog[]

  @@index([email])
  @@map("users")
}

// RefreshToken model - Persisted refresh tokens for revocable sessions
// Storing tokens server-side allows logout to truly invalidate a session.
model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ============================================================================
// CORE DOMAIN MODELS - REQ-001 Foundation
// ============================================================================

// Role model - Defines the executive roles in the system
// Executive roles supported:
// - CEO: Chief Executive Officer - Full access to all projects and tasks
// - CTO: Chief Technology Officer - Access to technical projects and tasks
// - COO: Chief Operating Officer - Access to operational projects and tasks
// Each user is assigned one primary role.
model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  workspaces  Workspace[]
  users       User[]

  @@map("roles")
}

// Workspace model - Isolated work areas for different organizational units
// Each workspace is associated with a specific role:
// - CEO Workspace: Cross-functional view
// - CTO Workspace: Technical focus
// - COO Workspace: Operations focus
model Workspace {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  roleId      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  role        Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  projects    Project[]
  tasks       Task[]

  @@unique([name, roleId])
  @@map("workspaces")
}

// Project model - High-level initiatives and programs
// Projects are containers for related issues, sprints, and milestones.
// Each project belongs to a specific workspace and has a unique key prefix
// used for auto-generating issue keys (e.g. DASH-1, DASH-2).
model Project {
  id            Int       @id @default(autoincrement())
  key           String    // Short uppercase identifier e.g. "DASH"
  name          String
  description   String?
  status        String    @default("active") // active, paused, completed, archived
  workspaceId   Int
  createdById   Int
  startDate     DateTime?
  endDate       DateTime?
  archivedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy     User      @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  issues        Issue[]
  sprints       Sprint[]
  milestones    Milestone[]
  tasks         Task[]

  @@unique([key, workspaceId])
  @@index([workspaceId])
  @@map("projects")
}

// Issue model - Work items within projects (replaces Task for REQ-003 scope)
// Issues have typed hierarchies (Epic > Story/Task/Bug > subtasks),
// auto-generated keys (PROJ-N), workflow states, story points, and sprint assignment.
model Issue {
  id              Int       @id @default(autoincrement())
  key             String    @unique  // e.g. "DASH-42"
  issueNumber     Int                // numeric part of key, scoped per project
  title           String
  description     String?
  type            String    @default("Task")    // Epic, Story, Task, Bug
  status          String    @default("Backlog") // Backlog, Ready, In Progress, In Review, Done, Closed
  priority        String    @default("Medium")  // Low, Medium, High, Critical
  estimate        Int?                           // story points (Fibonacci: 0,1,2,3,5,8,13,21)
  projectId       Int
  sprintId        Int?
  parentId        Int?                           // for hierarchy (Story under Epic, etc.)
  assigneeId      Int?
  reporterId      Int
  dueDate         DateTime?
  archivedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Voice feature fields (REQ-007)
  voiceCreated    Boolean   @default(false)
  voiceTranscript String?

  // Relations
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprint          Sprint?   @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  parent          Issue?    @relation("IssueHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children        Issue[]   @relation("IssueHierarchy")
  assignee        User?     @relation("IssueAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reporter        User      @relation("IssueReporter", fields: [reporterId], references: [id])
  comments        Comment[]
  activityLogs    ActivityLog[]
  outwardLinks    IssueLink[] @relation("IssueLinkSource")
  inwardLinks     IssueLink[] @relation("IssueLinkTarget")

  @@unique([projectId, issueNumber])
  @@index([projectId])
  @@index([sprintId])
  @@index([assigneeId])
  @@index([status])
  @@index([type])
  @@map("issues")
}

// Sprint model - Time-boxed iterations within a project
// Sprints collect issues for focused delivery. A project can have many sprints;
// only one sprint should be "active" at a time.
model Sprint {
  id          Int       @id @default(autoincrement())
  name        String
  goal        String?
  status      String    @default("planned") // planned, active, completed
  projectId   Int
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issues      Issue[]

  @@index([projectId])
  @@map("sprints")
}

// IssueLink model - Directed relationships between issues
// Link types: "blocks", "is blocked by", "relates to", "duplicates", "is duplicated by"
model IssueLink {
  id         Int    @id @default(autoincrement())
  sourceId   Int
  targetId   Int
  linkType   String // blocks, is_blocked_by, relates_to, duplicates, is_duplicated_by

  // Relations
  source     Issue  @relation("IssueLinkSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target     Issue  @relation("IssueLinkTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, linkType])
  @@index([sourceId])
  @@index([targetId])
  @@map("issue_links")
}

// Comment model - User comments on issues
model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  issueId   Int
  userId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([issueId])
  @@map("comments")
}

// ActivityLog model - Immutable audit trail for all issue changes
// Every status change, assignment, field edit, or sprint move is recorded here.
model ActivityLog {
  id        Int      @id @default(autoincrement())
  issueId   Int
  userId    Int
  action    String   // e.g. "status_changed", "assigned", "sprint_changed", "comment_added"
  field     String?  // the field that changed
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  // Relations
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([issueId])
  @@index([userId])
  @@map("activity_logs")
}

// Task model - Individual work items within projects
// Tasks are the primary unit of work. They:
// - Belong to a project (and thus a workspace)
// - Can be created via voice command (REQ-007)
// - Have status tracking (todo, in-progress, done, blocked)
// - Can be assigned priorities (low, medium, high, critical)
model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  status      String   @default("todo") // todo, in-progress, done, blocked
  priority    String   @default("medium") // low, medium, high, critical
  projectId   Int?
  workspaceId Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  dueDate     DateTime?
  
  // Voice feature fields (REQ-007)
  voiceCreated Boolean  @default(false)
  voiceTranscript String?

  // Relations
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([workspaceId])
  @@index([status])
  @@map("tasks")
}

// Milestone model - Key dates and deliverables for projects
// Milestones help track project progress and major deliverables.
model Milestone {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  dueDate     DateTime
  projectId   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("milestones")
}
